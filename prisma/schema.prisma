generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id                    Int                     @id @default(autoincrement()) @db.UnsignedInt
  name                  String                  @db.VarChar(255)
  email                 String                  @unique(map: "users_email_unique") @db.VarChar(255)
  email_verified_at     DateTime?               @db.Timestamp(0)
  password              String                  @db.VarChar(255)
  remember_token        String?                 @db.VarChar(100)
  created_at            DateTime?               @db.Timestamp(0)
  updated_at            DateTime?               @db.Timestamp(0)
  role                  String?                 @db.VarChar(100)
  halaqoh_attendance    halaqoh_attendance[]
  halaqoh_mentors       halaqoh_mentors?
  halaqoh_participants  halaqoh_participants[]
  promotions_given      halaqoh_promotions[]    @relation("promoter")
  promotions_received   halaqoh_promotions[]    @relation("promotee")
  halaqoh_registrations halaqoh_registrations[]
  post_categories       neo_post_categories[]
  neo_posts             neo_posts[]
}

model cache {
  key        String @id @db.VarChar(255)
  value      String @db.MediumText
  expiration Int
}

model cache_locks {
  key        String @id @db.VarChar(255)
  owner      String @db.VarChar(255)
  expiration Int
}

model failed_jobs {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  uuid       String   @unique(map: "failed_jobs_uuid_unique") @db.VarChar(255)
  connection String   @db.Text
  queue      String   @db.Text
  payload    String   @db.LongText
  exception  String   @db.LongText
  failed_at  DateTime @default(now()) @db.Timestamp(0)
}

model job_batches {
  id             String  @id @db.VarChar(255)
  name           String  @db.VarChar(255)
  total_jobs     Int
  pending_jobs   Int
  failed_jobs    Int
  failed_job_ids String  @db.LongText
  options        String? @db.MediumText
  cancelled_at   Int?
  created_at     Int
  finished_at    Int?
}

model jobs {
  id           Int    @id @default(autoincrement()) @db.UnsignedInt
  queue        String @db.VarChar(255)
  payload      String @db.LongText
  attempts     Int    @db.UnsignedTinyInt
  reserved_at  Int?   @db.UnsignedInt
  available_at Int    @db.UnsignedInt
  created_at   Int    @db.UnsignedInt

  @@index([queue], map: "jobs_queue_index")
}

model migrations {
  id        Int    @id @default(autoincrement()) @db.UnsignedInt
  migration String @db.VarChar(255)
  batch     Int
}

model neo_donation_public {
  id             Int                        @id @default(autoincrement()) @db.UnsignedInt
  invoice_number String                     @db.VarChar(255)
  name           String                     @db.VarChar(255)
  phone_number   String?                    @db.VarChar(255)
  note           String?                    @db.VarChar(255)
  amount         Decimal                    @db.Decimal(12, 2)
  payment_link   String?                    @db.VarChar(255)
  status         neo_donation_public_status @default(pending)
  created_at     DateTime?                  @default(now()) @db.Timestamp(0)
  updated_at     DateTime?                  @db.Timestamp(0)
  deleted_at     DateTime?                  @db.Timestamp(0)
  image          String?                    @db.VarChar(255)
}

model neo_postmeta {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  post_id    Int       @db.UnsignedInt
  meta_key   String    @db.VarChar(255)
  meta_value String    @db.LongText
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  neo_posts  neo_posts @relation(fields: [post_id], references: [id], onDelete: Cascade, map: "fk_neo_postmeta_to_neo_posts")

  @@index([post_id], map: "fk_neo_postmeta_to_neo_posts")
}

model neo_posts {
  id                  Int                  @id @default(autoincrement()) @db.UnsignedInt
  post_title          String               @db.Text
  post_excerpt        String?              @db.Text
  post_name           String               @db.Text
  post_content        String?              @db.LongText
  post_status         String               @db.VarChar(30)
  post_type           String               @db.VarChar(30)
  post_mime_type      String?              @db.VarChar(30)
  user_id             Int                  @db.UnsignedInt
  created_at          DateTime?            @db.Timestamp(0)
  updated_at          DateTime?            @db.Timestamp(0)
  post_category_id    Int?                 @db.UnsignedInt
  post_image          String?              @db.Text
  date                DateTime?
  code                String?              @db.VarChar(15)
  account             Int?                 @db.UnsignedInt
  program_category_id Int?                 @db.UnsignedInt
  count_view          Int?                 @default(0) @db.UnsignedInt
  neo_postmeta        neo_postmeta[]
  post_categories     neo_post_categories? @relation(fields: [post_category_id], references: [id], map: "fk_neo_posts_to_neo_post_categories")
  program             neo_programs?        @relation(fields: [program_category_id], references: [id], map: "fk_neo_posts_to_neo_programs")
  program_category    program_categories?  @relation(fields: [program_category_id], references: [id], map: "fk_neo_posts_to_program_categories")
  users               users                @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_neo_posts_to_users")

  @@index([user_id], map: "fk_neo_posts_to_users")
  @@index([post_category_id], map: "fk_neo_posts_to_neo_post_categories")
  @@index([program_category_id], map: "fk_neo_posts_to_neo_program_categories")
}

model neo_post_categories {
  id           Int            @id @default(autoincrement()) @db.UnsignedInt
  title        String         @db.VarChar(255)
  description  String?        @db.Text
  user_id      Int            @db.UnsignedInt
  created_at   DateTime?      @db.Timestamp(0)
  updated_at   DateTime?      @db.Timestamp(0)
  type         String?        @db.VarChar(15)
  users        users          @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_neo_post_categories_to_users")
  neo_posts    neo_posts[]
  neo_programs neo_programs[]

  @@index([user_id], map: "fk_neo_post_categories_to_users")
}

model neo_termmeta {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  term_id    Int       @db.UnsignedInt
  meta_key   String    @db.VarChar(255)
  meta_value String    @db.LongText
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  neo_terms  neo_terms @relation(fields: [term_id], references: [id], onDelete: Cascade, map: "fk_neo_termmeta_to_neo_terms")

  @@index([term_id], map: "fk_neo_termmeta_to_neo_terms")
}

model neo_terms {
  id           Int            @id @default(autoincrement()) @db.UnsignedInt
  name         String         @db.VarChar(255)
  slug         String         @db.VarChar(255)
  created_at   DateTime?      @db.Timestamp(0)
  updated_at   DateTime?      @db.Timestamp(0)
  neo_termmeta neo_termmeta[]
}

model password_reset_tokens {
  email      String    @id @db.VarChar(255)
  token      String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
}

model sessions {
  id            String  @id @db.VarChar(255)
  user_id       Int?    @db.UnsignedInt
  ip_address    String? @db.VarChar(45)
  user_agent    String? @db.Text
  payload       String  @db.LongText
  last_activity Int

  @@index([last_activity], map: "sessions_last_activity_index")
  @@index([user_id], map: "sessions_user_id_index")
}

model neo_programs {
  id                  Int                 @id @default(autoincrement()) @db.UnsignedInt
  title               String?             @db.VarChar(255)
  slug                String?             @db.VarChar(255)
  content             String?             @db.LongText
  user_id             Int?                @db.UnsignedInt
  image               String?
  created_at          DateTime?           @db.DateTime(0)
  updated_at          DateTime?           @db.DateTime(0)
  program_category_id Int                 @db.UnsignedInt
  date                DateTime?           @db.DateTime(0)
  description         String?             @db.Text
  programs            neo_posts[]
  programCategories   neo_post_categories @relation(fields: [program_category_id], references: [id], map: "fk_programs_to_postCategories")

  @@index([program_category_id], map: "fk_programs_to_postCategories")
  @@map("neo_programs")
}

model sliders {
  id          Int       @id @default(autoincrement()) @db.UnsignedInt
  image       String?   @db.Text
  type        String?   @db.VarChar(20)
  description String?   @db.VarChar(255)
  user_id     Int
  created_at  DateTime? @db.DateTime(0)
  updated_at  DateTime? @db.DateTime(0)

  @@index([user_id])
}

model program_categories {
  id          Int         @id @default(autoincrement()) @db.UnsignedInt
  title       String?     @db.VarChar(255)
  description String?     @db.Text
  userCreate  Int?
  createdAt   DateTime?   @db.DateTime(0)
  updatedAt   DateTime?   @db.DateTime(0)
  account     Int?
  image       String?     @db.Text
  programs    neo_posts[]
}

model settings {
  id    Int     @id @default(autoincrement()) @db.UnsignedInt
  key   String? @db.VarChar(255)
  label String? @db.LongText
  type  String? @db.VarChar(50)
  value String? @db.LongText
}

model halaqoh_categories {
  id              Int                       @id @default(autoincrement()) @db.UnsignedInt
  title           String                    @db.VarChar(255)
  slug            String                    @unique @db.VarChar(255)
  description     String?                   @db.Text
  created_at      DateTime?                 @db.Timestamp(0)
  updated_at      DateTime?                 @db.Timestamp(0)
  image           String?                   @db.VarChar(255)
  link_meet       String?                   @db.Text
  date_test       DateTime?                 @db.DateTime(0)
  material_levels halaqoh_material_levels[]
  promotions      halaqoh_promotions[]
  registrations   halaqoh_registrations[]
  halaqohs        halaqohs[]
}

model halaqoh_mentors {
  id             Int        @id @default(autoincrement()) @db.UnsignedInt
  user_id        Int        @unique @db.UnsignedInt
  bio            String?    @db.Text
  specialization String?    @db.VarChar(255)
  is_active      Boolean    @default(true)
  created_at     DateTime?  @db.Timestamp(0)
  updated_at     DateTime?  @db.Timestamp(0)
  user           users      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  halaqohs       halaqohs[]
}

model halaqohs {
  id                Int                      @id @default(autoincrement()) @db.UnsignedInt
  category_id       Int                      @db.UnsignedInt
  mentor_id         Int                      @db.UnsignedInt
  title             String                   @db.VarChar(255)
  schedule_info     String?                  @db.Text
  location_type     halaqoh_location         @default(ONLINE)
  meeting_link      String?                  @db.VarChar(255)
  status            halaqoh_status           @default(OPEN)
  created_at        DateTime?                @db.Timestamp(0)
  updated_at        DateTime?                @db.Timestamp(0)
  material_level_id Int?                     @db.UnsignedInt
  attendance        halaqoh_attendance[]
  participants      halaqoh_participants[]
  promotions_from   halaqoh_promotions[]     @relation("promotion_from")
  promotions_to     halaqoh_promotions[]     @relation("promotion_to")
  category          halaqoh_categories       @relation(fields: [category_id], references: [id])
  material_level    halaqoh_material_levels? @relation(fields: [material_level_id], references: [id])
  mentor            halaqoh_mentors          @relation(fields: [mentor_id], references: [id])

  @@index([category_id], map: "halaqohs_category_id_fkey")
  @@index([mentor_id], map: "halaqohs_mentor_id_fkey")
  @@index([material_level_id])
}

model halaqoh_registrations {
  id           Int                 @id @default(autoincrement()) @db.UnsignedInt
  user_id      Int                 @db.UnsignedInt
  category_id  Int                 @db.UnsignedInt
  status       registration_status @default(PENDING)
  test_score   Int?
  notes        String?             @db.Text
  created_at   DateTime?           @db.Timestamp(0)
  updated_at   DateTime?           @db.Timestamp(0)
  address      String?             @db.Text
  gender       String?             @db.VarChar(10)
  phone_number String?             @db.VarChar(20)
  date         DateTime?           @db.Date
  date_test    DateTime?           @db.DateTime(0)
  category     halaqoh_categories  @relation(fields: [category_id], references: [id])
  user         users               @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([category_id], map: "halaqoh_registrations_category_id_fkey")
  @@index([user_id], map: "halaqoh_registrations_user_id_fkey")
}

model halaqoh_participants {
  id         Int                @id @default(autoincrement()) @db.UnsignedInt
  halaqoh_id Int                @db.UnsignedInt
  user_id    Int                @db.UnsignedInt
  status     participant_status @default(ACTIVE)
  joined_at  DateTime?          @default(now()) @db.Timestamp(0)
  notes      String?            @db.Text
  halaqoh    halaqohs           @relation(fields: [halaqoh_id], references: [id], onDelete: Cascade)
  user       users              @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([halaqoh_id], map: "halaqoh_participants_halaqoh_id_fkey")
  @@index([user_id], map: "halaqoh_participants_user_id_fkey")
}

model halaqoh_attendance {
  id         Int               @id @default(autoincrement()) @db.UnsignedInt
  halaqoh_id Int               @db.UnsignedInt
  user_id    Int               @db.UnsignedInt
  date       DateTime          @db.Date
  status     attendance_status @default(HADIR)
  notes      String?           @db.VarChar(255)
  halaqoh    halaqohs          @relation(fields: [halaqoh_id], references: [id], onDelete: Cascade)
  user       users             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([halaqoh_id, user_id, date])
  @@index([halaqoh_id], map: "halaqoh_attendance_halaqoh_id_fkey")
  @@index([user_id], map: "halaqoh_attendance_user_id_fkey")
}

model halaqoh_material_levels {
  id              Int                  @id @default(autoincrement()) @db.UnsignedInt
  category_id     Int                  @db.UnsignedInt
  title           String               @db.VarChar(255)
  level_order     Int                  @db.UnsignedInt
  description     String?              @db.Text
  created_at      DateTime?            @db.Timestamp(0)
  updated_at      DateTime?            @db.Timestamp(0)
  category        halaqoh_categories   @relation(fields: [category_id], references: [id])
  promotions_from halaqoh_promotions[] @relation("from_level")
  promotions_to   halaqoh_promotions[] @relation("to_level")
  halaqohs        halaqohs[]

  @@unique([category_id, level_order])
  @@index([category_id])
}

model halaqoh_promotions {
  id              Int                      @id @default(autoincrement()) @db.UnsignedInt
  user_id         Int                      @db.UnsignedInt
  category_id     Int                      @db.UnsignedInt
  from_halaqoh_id Int?                     @db.UnsignedInt
  to_halaqoh_id   Int                      @db.UnsignedInt
  from_level_id   Int?                     @db.UnsignedInt
  to_level_id     Int                      @db.UnsignedInt
  type            promotion_type           @default(PROMOTION)
  test_score      Int?
  notes           String?                  @db.Text
  promoted_by     Int                      @db.UnsignedInt
  promoted_at     DateTime                 @default(now()) @db.Timestamp(0)
  category        halaqoh_categories       @relation(fields: [category_id], references: [id])
  from_halaqoh    halaqohs?                @relation("promotion_from", fields: [from_halaqoh_id], references: [id])
  from_level      halaqoh_material_levels? @relation("from_level", fields: [from_level_id], references: [id])
  admin           users                    @relation("promoter", fields: [promoted_by], references: [id])
  to_halaqoh      halaqohs                 @relation("promotion_to", fields: [to_halaqoh_id], references: [id])
  to_level        halaqoh_material_levels  @relation("to_level", fields: [to_level_id], references: [id])
  user            users                    @relation("promotee", fields: [user_id], references: [id])

  @@index([user_id])
  @@index([category_id])
  @@index([from_halaqoh_id], map: "halaqoh_promotions_from_halaqoh_id_fkey")
  @@index([from_level_id], map: "halaqoh_promotions_from_level_id_fkey")
  @@index([promoted_by], map: "halaqoh_promotions_promoted_by_fkey")
  @@index([to_halaqoh_id], map: "halaqoh_promotions_to_halaqoh_id_fkey")
  @@index([to_level_id], map: "halaqoh_promotions_to_level_id_fkey")
}

model Itikaf {
  id         Int     @id @default(autoincrement()) @db.UnsignedInt
  name       String  @db.VarChar(50)
  phone      String  @db.VarChar(20)
  address    String  @db.Text
  identitas  String  @db.Text
  umur       Int
  gender     String  @db.VarChar(10)
  surat_izin String?  @db.Text
  createdAt  DateTime @default(now()) @db.Timestamp(0)

  @@map("itikaf")
}

model page_visits {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  path         String   @db.VarChar(512)
  route_key    String   @db.VarChar(255)
  visited_at   DateTime @default(now()) @db.DateTime(0)
  visitor_hash String   @db.Char(64)
  session_id   String?  @db.VarChar(64)
  referrer     String?  @db.VarChar(1024)
  user_agent   String?  @db.VarChar(512)
  created_at   DateTime @default(now()) @db.DateTime(0)
  ip_address   String?  @db.VarChar(50)

  @@index([path, visited_at], map: "idx_page_visits_path_visited")
  @@index([route_key, visited_at], map: "idx_page_visits_route_visited")
  @@index([session_id, visited_at], map: "idx_page_visits_session_visited")
  @@index([visited_at], map: "idx_page_visits_visited_at")
  @@index([visitor_hash, visited_at], map: "idx_page_visits_visitor_visited")
}

enum neo_donation_public_status {
  pending
  settled
  expired
  failed
}

enum halaqoh_location {
  ONLINE
  OFFLINE
}

enum halaqoh_status {
  OPEN
  CLOSED
}

enum registration_status {
  PENDING
  TESTING
  ACCEPTED
  REJECTED
  COMPLETED
}

enum participant_status {
  ACTIVE
  GRADUATED
  DROPPED
}

enum attendance_status {
  HADIR
  IZIN
  SAKIT
  ALPA
}

enum promotion_type {
  PROMOTION
  DEMOTION
  INITIAL_PLACEMENT
}
